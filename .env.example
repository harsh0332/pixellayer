# Public site URL — used for canonical, OG, sitemap and JSON-LD.
# Set on Vercel to the production domain (falls back to localhost in dev).
NEXT_PUBLIC_SITE_URL=

# Contact section integrations — all optional; the UI degrades gracefully
# when unset (no crashes, no fake success states).

# Where the project-brief form POSTs its JSON payload ({ formType: "project-brief", ... })
NEXT_PUBLIC_FORM_WEBHOOK=

# Cal.com / Calendly (or compatible) booking page — embedded when set
NEXT_PUBLIC_BOOKING_URL=

# WhatsApp number in international format without "+" (e.g. 91XXXXXXXXXX)
NEXT_PUBLIC_WHATSAPP=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Unset = no analytics script.
NEXT_PUBLIC_GA_ID=

# Google Search Console HTML-tag verification token. Unset = no meta tag.
NEXT_PUBLIC_GSC_VERIFICATION=
